generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("article")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feeds     Feed[]
}

model Feed {
  id          String    @id @default(cuid())
  title       String
  url         String    @unique
  siteUrl     String?
  description String?
  imageUrl    String?
  type         String    @default("article")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  refreshingAt DateTime?
  articles     Article[]
  folderId     String?
  folder      Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
}

model Article {
  id                 String    @id @default(cuid())
  title              String
  link               String
  content            String?
  readabilityContent String?
  summary            String?
  imageUrl           String?
  pubDate            DateTime?
  isRead             Boolean   @default(false)
  isStarred          Boolean   @default(false)
  feedId             String
  feed               Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())

  @@unique([feedId, link])
  @@index([feedId])
  @@index([pubDate])
  @@index([isStarred])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AiCache {
  id        String   @id @default(cuid())
  articleId String
  type      String   // translate, translate-lite, summarize
  language  String   // target language
  result    String   // JSON string of cached result
  createdAt DateTime @default(now())

  @@unique([articleId, type, language])
  @@index([articleId])
}
