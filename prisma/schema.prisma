generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Folder {
  id        String   @id @default(cuid())
  name      String   @unique
  type      String   @default("article")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feeds     Feed[]
}

model Feed {
  id            String    @id @default(cuid())
  title         String
  url           String    @unique
  siteUrl       String?
  description   String?
  imageUrl      String?
  type          String    @default("article")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  refreshingAt  DateTime?
  lastFetchedAt DateTime?
  errorCount    Int       @default(0)
  lastError     String?
  errorAt       DateTime?
  articles      Article[]
  folderId      String?
  folder        Folder?   @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([folderId])
  @@index([type])
}

model Article {
  id                 String    @id @default(cuid())
  title              String
  link               String
  guid               String?
  content            String?
  readabilityContent String?
  summary            String?
  imageUrl           String?
  pubDate            DateTime?
  isRead             Boolean   @default(false)
  isStarred          Boolean   @default(false)
  feedId             String
  feed               Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  aiCaches           AiCache[]

  @@unique([feedId, link])
  @@index([feedId])
  @@index([pubDate])
  @@index([isStarred])
  @@index([isRead])
  @@index([feedId, isRead])
  @@index([feedId, pubDate])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AiCache {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  type      String
  language  String
  result    String
  createdAt DateTime @default(now())

  @@unique([articleId, type, language])
  @@index([articleId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
